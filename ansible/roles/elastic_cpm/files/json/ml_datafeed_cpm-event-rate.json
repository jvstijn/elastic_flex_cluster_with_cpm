{
  "job_id": "cpm-event-rate",
  "indices": ["monitoring:.monitoring-es-8-*"],
  "query": {
    "bool": {
      "filter": [
        { "match_phrase": { "event.dataset": "elasticsearch.index" } },
        { "wildcard":     { "elasticsearch.index.name": ".ds-logs-*" } }
      ]
    }
  },
  "query_delay": "67193ms",
  "chunking_config": { "mode": "manual", "time_span": "900000ms" },
  "indices_options": {
    "ignore_unavailable": false,
    "expand_wildcards": ["open"],
    "allow_no_indices": true,
    "ignore_throttled": true
  },
  "runtime_mappings": {
    "ds_name": {
      "type": "keyword",
      "script": {
        "source": "String name = doc['elasticsearch.index.name'].value; if (!name.startsWith('.ds-logs-')) { return; } name = name.substring(4); int p1 = name.lastIndexOf('-'); if (p1 > 0) { name = name.substring(0, p1); } int p2 = name.lastIndexOf('-'); if (p2 > 0) { name = name.substring(0, p2); } emit(name);"
      }
    }
  },
  "aggregations": {
    "buckets": {
      "date_histogram": { "field": "@timestamp", "fixed_interval": "15m" },
      "aggregations": {
        "@timestamp": { "max": { "field": "@timestamp" } },
        "ds_group": {
          "terms": { "field": "ds_name", "size": 1000 },
          "aggregations": {
            "index_total": { "max": { "field": "elasticsearch.index.total.indexing.index_total" } },
            "doc_count":   { "value_count": { "field": "@timestamp" } }
          }
        }
      }
    }
  },
  "scroll_size": 1000,
  "delayed_data_check_config": { "enabled": true }
}
