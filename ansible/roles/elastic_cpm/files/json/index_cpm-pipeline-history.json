        "type": "keyword"
      },
      "namespace": {
        "type": "keyword"
      },
      "pipeline_type": {
        "type": "keyword"
      },
      "pipeline_id": {
        "type": "keyword"
      },
      "cluster_id": {
        "type": "keyword"
      },
      "cluster_name": {
        "type": "keyword"
      },
      "previous_cluster_id": {
        "type": "keyword"
      },
      "topic": {
        "type": "keyword"
      },
      "dc": {
        "type": "keyword"
      },
      "move_detected": {
        "type": "boolean"
      },
