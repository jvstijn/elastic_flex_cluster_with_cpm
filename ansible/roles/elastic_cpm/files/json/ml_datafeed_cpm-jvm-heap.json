{
  "job_id": "cpm-jvm-heap",
  "indices": ["monitoring:.monitoring-es-8-*"],
  "query": {
    "bool": {
      "filter": [
        { "match_phrase": { "event.dataset": "elasticsearch.node.stats" } }
      ]
    }
  },
  "query_delay": "100580ms",
  "chunking_config": { "mode": "manual", "time_span": "900000ms" },
  "indices_options": {
    "ignore_unavailable": false,
    "expand_wildcards": ["open"],
    "allow_no_indices": true,
    "ignore_throttled": true
  },
  "aggregations": {
    "buckets": {
      "date_histogram": { "field": "@timestamp", "fixed_interval": "15m" },
      "aggregations": {
        "@timestamp": { "max": { "field": "@timestamp" } },
        "cluster_id": {
          "terms": { "field": "elasticsearch.cluster.id", "size": 10 },
          "aggregations": {
            "heap_pct":  { "avg": { "field": "elasticsearch.node.stats.jvm.mem.heap.used.pct" } },
            "doc_count": { "value_count": { "field": "@timestamp" } }
          }
        }
      }
    }
  },
  "scroll_size": 1000,
  "delayed_data_check_config": { "enabled": true }
}
