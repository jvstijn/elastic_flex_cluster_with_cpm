{% raw %}
{
  "trigger": {
    "schedule": {
      "cron": "0 59 23 31 2 ?"
    }
  },
  "input": {
    "chain": {
      "inputs": [
        {
          "state": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-pipeline-state"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 500
                }
              }
            }
          }
        },
        {
          "registry": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-cluster-registry"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 20,
                  "query": {
                    "term": {
                      "active": true
                    }
                  },
                  "_source": [
                    "cluster_id",
                    "cluster_uuid",
                    "cluster_name",
                    "ingest_hosts",
                    "dc"
                  ]
                }
              }
            }
          }
        },
        {
          "template_dedicated": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-pipeline-templates"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 1,
                  "query": {
                    "term": {
                      "_id": "dedicated"
                    }
                  }
                }
              }
            }
          }
        },
        {
          "template_catchall": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-pipeline-templates"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 1,
                  "query": {
                    "term": {
                      "_id": "catchall"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  },
  "condition": {
    "always": {}
  },
  "actions": {
    "push_pipelines": {
      "foreach": "ctx.payload.pipelines",
      "max_iterations": 20,
      "webhook": {
        "scheme": "https",
{% endraw %}
        "host": "{{ webhook_host }}",
{% raw %}
        "port": 9200,
        "method": "put",
        "path": "/_logstash/pipeline/{{ctx.payload.pipeline_id}}",
        "params": {},
        "headers": {
          "Content-Type": "application/json",
{% endraw %}
          "Authorization": "Apikey {{ watcher_api_key.encoded  }}"
{% raw %}
        },
        "body": "{{{ctx.payload.body}}}"
      }
    }
  },
  "transform": {
    "script": {
      "source": "// ====== CPM Pipeline Pusher ======\n// Reads state from cpm-pipeline-state, renders pipeline configs, and pushes to Logstash\n\n// JSON-escape helper characters\nString BS  = Character.toString((char)92);\nString DQ  = Character.toString((char)34);\nString NL  = Character.toString((char)10);\nString CR  = Character.toString((char)13);\nString TAB = Character.toString((char)9);\n\nString ts = ctx.execution_time.toString();\n\n// Build registry map\nMap registryMap = new HashMap();\nfor (def hit : ctx.payload.registry.hits.hits) {\n  Map src = hit._source;\n  String cid = (String)src.cluster_id;\n  Map m = new HashMap();\n  m.put('cluster_id', cid);\n  m.put('cluster_uuid', (String)src.cluster_uuid);\n  m.put('cluster_name', src.cluster_name != null ? (String)src.cluster_name : '');\n  m.put('ingest_hosts', src.ingest_hosts != null ? (String)src.ingest_hosts : '');\n  m.put('dc', src.dc != null ? (String)src.dc : '');\n  registryMap.put(cid, m);\n}\n\n// Read templates from search results\nString kafkaBootstrap = 'kafka:9092';\nString dedicatedTpl = '';\nlong dedicatedConsumerThreads = 1;\nMap dedicatedSettings = new HashMap();\nif (ctx.payload.template_dedicated.hits.total > 0) {\n  for (def hit : ctx.payload.template_dedicated.hits.hits) {\n    if ('dedicated'.equals((String)hit._id)) {\n      dedicatedTpl = (String)hit._source.template;\n      def ct = hit._source.consumer_threads;\n      if (ct != null) dedicatedConsumerThreads = ct;\n      def kb = hit._source.kafka_bootstrap;\n      if (kb != null) kafkaBootstrap = (String)kb;\n      def ps = hit._source.pipeline_settings;\n      if (ps != null) dedicatedSettings = (Map)ps;\n      break;\n    }\n  }\n}\nString catchallTpl = '';\nlong catchallConsumerThreads = 1;\nMap catchallSettings = new HashMap();\nif (ctx.payload.template_catchall.hits.total > 0) {\n  for (def hit : ctx.payload.template_catchall.hits.hits) {\n    if ('catchall'.equals((String)hit._id)) {\n      catchallTpl = (String)hit._source.template;\n      def ct = hit._source.consumer_threads;\n      if (ct != null) catchallConsumerThreads = ct;\n      def ps = hit._source.pipeline_settings;\n      if (ps != null) catchallSettings = (Map)ps;\n      break;\n    }\n  }\n}\n\n// Group state entries by pipeline_id\nMap pipelineGroups = new HashMap();    // pipeline_id -> List of state entries\nMap pipelineTypes = new HashMap();     // pipeline_id -> 'dedicated' or 'catchall'\nMap pipelineClusters = new HashMap();  // pipeline_id -> cluster_id\nMap pipelineDcs = new HashMap();      // pipeline_id -> dc\n\nfor (def hit : ctx.payload.state.hits.hits) {\n  Map src = hit._source;\n  if (src.data_stream_type == null) continue;\n  String pid = (String)src.pipeline_id;\n  String ptype = (String)src.pipeline_type;\n  String cid = (String)src.cluster_id;\n  String dc = src.dc != null ? (String)src.dc : 'default';\n\n  if (!pipelineGroups.containsKey(pid)) {\n    pipelineGroups.put(pid, new ArrayList());\n    pipelineTypes.put(pid, ptype);\n    pipelineClusters.put(pid, cid);\n    pipelineDcs.put(pid, dc);\n  }\n  ((List)pipelineGroups.get(pid)).add(src);\n}\n\n// Build pipelines\nList pipelines = new ArrayList();\n\nfor (def entry : pipelineGroups.entrySet()) {\n  String pid = (String)entry.getKey();\n  List entries = (List)entry.getValue();\n  String ptype = (String)pipelineTypes.get(pid);\n  String cid = (String)pipelineClusters.get(pid);\n  String dc = (String)pipelineDcs.get(pid);\n\n  Map cluster = (Map)registryMap.get(cid);\n  if (cluster == null) continue;\n  String ingestHosts = (String)cluster.get('ingest_hosts');\n  if (ingestHosts == null || ingestHosts.isEmpty()) continue;\n  String clusterName = (String)cluster.get('cluster_name');\n  if (clusterName == null || clusterName.isEmpty()) clusterName = cid;\n  String groupId = 'cpm-' + clusterName;\n\n  String esHostsStr = DQ + ingestHosts.replace(',', ':9200' + DQ + ',' + DQ) + ':9200' + DQ;\n  String apiKeyVar = 'ES_API_KEY_' + cid.toUpperCase().replace('-', '_');\n\n  String config;\n  String description;\n\n  if ('dedicated'.equals(ptype)) {\n    // Dedicated: single dataset pipeline (prefer type-prefixed topic)\n    Map first = null;\n    for (def e : entries) {\n      Map m = (Map)e;\n      if (m.data_stream_type == null) continue;\n      String ds = (String)m.dataset;\n      String ns = m.namespace != null ? (String)m.namespace : 'default';\n      String st = (String)m.data_stream_type;\n      String expected = st + '-' + ds + '-' + ns;\n      String t = m.topic != null ? (String)m.topic : expected;\n      if (first == null || expected.equals(t)) first = m;\n    }\n    if (first == null) continue;\n    String dataset = (String)first.dataset;\n    String namespace = first.namespace != null ? (String)first.namespace : 'default';\n    String streamType = (String)first.data_stream_type;\n    String topic = streamType + '-' + dataset + '-' + namespace;\n\n    config = dedicatedTpl\n      .replace('__KAFKA_BOOTSTRAP__', kafkaBootstrap)\n      .replace('__TOPIC__', topic)\n      .replace('__PIPELINE_ID__', pid)\n      .replace('__GROUP_ID__', groupId)\n      .replace('__CONSUMER_THREADS__', String.valueOf(dedicatedConsumerThreads))\n      .replace('__ES_HOSTS__', esHostsStr)\n      .replace('__DATA_STREAM_TYPE__', streamType)\n      .replace('__DATASET__', dataset)\n      .replace('__NAMESPACE__', namespace)\n      .replace('__API_KEY_VAR__', apiKeyVar);\n\n    description = 'CPM dedicated pipeline to ' + cid + ' (' + dataset + ')';\n  } else {\n    // Catchall: multiple topics (dedupe, type-prefixed)\n    Set topicSet = new LinkedHashSet();\n    for (def e : entries) {\n      Map m = (Map)e;\n      if (m.data_stream_type == null) continue;\n      String ds = (String)m.dataset;\n      String ns = m.namespace != null ? (String)m.namespace : 'default';\n      String st = (String)m.data_stream_type;\n      String t = m.topic != null ? (String)m.topic : st + '-' + ds + '-' + ns;\n      if (!t.startsWith('logs-') && !t.startsWith('metrics-') && !t.startsWith('traces-')) {\n        t = st + '-' + ds + '-' + ns;\n      }\n      topicSet.add(t);\n    }\n    if (topicSet.isEmpty()) continue;\n    String topicsList = '';\n    int ti = 0;\n    for (def topic : topicSet) {\n      if (ti > 0) topicsList = topicsList + ', ';\n      topicsList = topicsList + DQ + topic + DQ;\n      ti++;\n    }\n\n    config = catchallTpl\n      .replace('__KAFKA_BOOTSTRAP__', kafkaBootstrap)\n      .replace('__TOPICS_LIST__', topicsList)\n      .replace('__CLUSTER_ID__', cid)\n      .replace('__GROUP_ID__', groupId)\n      .replace('__CONSUMER_THREADS__', String.valueOf(catchallConsumerThreads))\n      .replace('__ES_HOSTS__', esHostsStr)\n      .replace('__API_KEY_VAR__', apiKeyVar);\n\n    description = 'CPM catch-all pipeline for ' + cid + ' (' + entries.size() + ' datasets)';\n  }\n\n  // Build pipeline_settings from template (numbers unquoted, strings quoted)\n  Map settings = 'dedicated'.equals(ptype) ? dedicatedSettings : catchallSettings;\n  String settingsStr = '';\n  int si = 0;\n  for (def se : settings.entrySet()) {\n    String skey = (String)se.getKey();\n    def sval = se.getValue();\n    if (si > 0) settingsStr = settingsStr + ',';\n    if (sval instanceof Number) {\n      settingsStr = settingsStr + DQ + skey + DQ + ':' + String.valueOf(sval);\n    } else {\n      settingsStr = settingsStr + DQ + skey + DQ + ':' + DQ + String.valueOf(sval) + DQ;\n    }\n    si++;\n  }\n\n  String esc = config.replace(BS, BS + BS).replace(DQ, BS + DQ).replace(NL, BS + 'n').replace(CR, BS + 'r').replace(TAB, BS + 't');\n\n  String body = '{' +\n    DQ + 'description' + DQ + ':' + DQ + description + DQ + ',' +\n    DQ + 'last_modified' + DQ + ':' + DQ + ts + DQ + ',' +\n    DQ + 'pipeline_metadata' + DQ + ':{' + DQ + 'type' + DQ + ':' + DQ + 'logstash_pipeline' + DQ + ',' + DQ + 'version' + DQ + ':1},' +\n    DQ + 'pipeline' + DQ + ':' + DQ + esc + DQ + ',' +\n    DQ + 'pipeline_settings' + DQ + ':{' + settingsStr + '},' +\n    DQ + 'username' + DQ + ':' + DQ + 'cpm' + DQ +\n    '}';\n\n  Map p = new HashMap();\n  p.put('pipeline_id', pid);\n  p.put('body', body);\n  pipelines.add(p);\n}\n\nMap out = new HashMap();\nout.put('pipelines', pipelines);\nreturn out;",
      "lang": "painless"
    }
  }
}
{% endraw %}
