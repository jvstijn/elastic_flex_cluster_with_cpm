{
  "trigger": { "schedule": { "cron": "0 15 0 * * ?" } },
  "input": {
    "chain": {
      "inputs": [
        { "registry": { "search": { "request": {
            "search_type": "query_then_fetch",
            "indices": ["cpm-cluster-registry"],
            "rest_total_hits_as_int": true,
            "body": { "size": 10, "query": { "term": { "active": true } } }
        } } } },
        { "disk_forecast": { "search": { "request": {
            "search_type": "query_then_fetch",
            "indices": [".ml-anomalies-*"],
            "rest_total_hits_as_int": true,
            "body": {
              "size": 0,
              "query": { "bool": { "filter": [
                { "term":  { "job_id": "cpm-store-size" } },
                { "term":  { "result_type": "model_forecast" } },
                { "range": { "timestamp": { "gte": "now", "lte": "now+24h" } } }
              ] } },
              "aggs": {
                "by_cluster": {
                  "terms": { "field": "partition_field_value", "size": 10 },
                  "aggs":  { "peak": { "max": { "field": "forecast_prediction" } } }
                }
              }
            }
        } } } },
        { "jvm_forecast": { "search": { "request": {
            "search_type": "query_then_fetch",
            "indices": [".ml-anomalies-*"],
            "rest_total_hits_as_int": true,
            "body": {
              "size": 0,
              "query": { "bool": { "filter": [
                { "term":  { "job_id": "cpm-jvm-heap" } },
                { "term":  { "result_type": "model_forecast" } },
                { "range": { "timestamp": { "gte": "now", "lte": "now+24h" } } }
              ] } },
              "aggs": {
                "by_cluster": {
                  "terms": { "field": "partition_field_value", "size": 10 },
                  "aggs":  { "peak": { "max": { "field": "forecast_prediction" } } }
                }
              }
            }
        } } } },
        { "shard_forecast": { "search": { "request": {
            "search_type": "query_then_fetch",
            "indices": [".ml-anomalies-*"],
            "rest_total_hits_as_int": true,
            "body": {
              "size": 0,
              "query": { "bool": { "filter": [
                { "term":  { "job_id": "cpm-shard-count" } },
                { "term":  { "result_type": "model_forecast" } },
                { "range": { "timestamp": { "gte": "now", "lte": "now+24h" } } }
              ] } },
              "aggs": {
                "by_cluster": {
                  "terms": { "field": "partition_field_value", "size": 10 },
                  "aggs":  { "peak": { "max": { "field": "forecast_prediction" } } }
                }
              }
            }
        } } } },
        { "load_forecast": { "search": { "request": {
            "search_type": "query_then_fetch",
            "indices": [".ml-anomalies-*"],
            "rest_total_hits_as_int": true,
            "body": {
              "size": 0,
              "query": { "bool": { "filter": [
                { "term":  { "job_id": "cpm-cluster-event-rate" } },
                { "term":  { "result_type": "model_forecast" } },
                { "range": { "timestamp": { "gte": "now", "lte": "now+24h" } } }
              ] } },
              "aggs": {
                "by_cluster": {
                  "terms": { "field": "partition_field_value", "size": 10 },
                  "aggs":  { "peak": { "max": { "field": "forecast_prediction" } } }
                }
              }
            }
        } } } }
      ]
    }
  },
  "condition": { "always": {} },
  "transform": {
    "script": {
      "source": "Map diskMap = new HashMap(); Map jvmMap = new HashMap(); Map shardMap = new HashMap(); Map loadMap = new HashMap(); Map regMap = new HashMap(); for (def b : ctx.payload.disk_forecast.aggregations.by_cluster.buckets) diskMap[b.key] = b.peak.value != null ? ((Number)b.peak.value).doubleValue() : 0.0; for (def b : ctx.payload.jvm_forecast.aggregations.by_cluster.buckets) jvmMap[b.key] = b.peak.value != null ? ((Number)b.peak.value).doubleValue() : 0.0; for (def b : ctx.payload.shard_forecast.aggregations.by_cluster.buckets) shardMap[b.key] = b.peak.value != null ? ((Number)b.peak.value).doubleValue() : 0.0; for (def b : ctx.payload.load_forecast.aggregations.by_cluster.buckets) loadMap[b.key] = b.peak.value != null ? ((Number)b.peak.value).doubleValue() : 0.0; for (def hit : ctx.payload.registry.hits.hits) regMap[hit._source.cluster_uuid] = hit._source; List clusters = new ArrayList(); for (def uuid : regMap.keySet()) { def reg = regMap[uuid]; double dtotal = reg['disk_total_bytes'] != null ? ((Number)reg['disk_total_bytes']).doubleValue() : 1.0; double smax = reg['shard_max_threshold'] != null ? ((Number)reg['shard_max_threshold']).doubleValue() : 1000.0; double qthresh = reg['write_queue_threshold'] != null ? ((Number)reg['write_queue_threshold']).doubleValue() : 50.0; double diskB = diskMap.containsKey(uuid) ? diskMap[uuid] : 0.0; double jvmP = jvmMap.containsKey(uuid) ? jvmMap[uuid] : 0.0; double shardC = shardMap.containsKey(uuid) ? shardMap[uuid] : 0.0; double queueD = loadMap.containsKey(uuid) ? loadMap[uuid] : 0.0; double diskScore = dtotal > 0 ? (diskB / dtotal) * 100.0 : 0.0; double jvmScore = jvmP; double shardScore = smax > 0 ? (shardC / smax) * 100.0 : 0.0; double loadScore = qthresh > 0 ? (queueD / qthresh) * 100.0 : 0.0; double total = 0.50*diskScore + 0.25*jvmScore + 0.05*shardScore + 0.20*loadScore; Map c = new HashMap(); c['cluster_id'] = reg['cluster_id']; c['cluster_uuid'] = uuid; c['disk_used_pct_forecast'] = diskScore; c['jvm_heap_pct_forecast'] = jvmScore; c['shard_score'] = shardScore; c['write_queue_forecast'] = queueD; c['load_score'] = loadScore; c['total_score'] = total; c['alert'] = total > 80.0; clusters.add(c); } Map out = new HashMap(); out['scored_at'] = ctx.execution_time.toString(); out['forecast_horizon_hours'] = 24; out['clusters'] = clusters; return out;",
      "lang": "painless"
    }
  },
  "actions": {
    "write_scores": {
      "index": { "index": "cpm-scores" }
    }
  },
  "metadata": { "xpack": { "type": "json" } }
}
