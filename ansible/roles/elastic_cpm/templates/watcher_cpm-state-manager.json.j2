{
  "trigger": {
    "schedule": {
      "cron": "0 15 0 * * ?"
    }
  },
  "input": {
    "chain": {
      "inputs": [
        {
          "routing_suggestions": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-routing-suggestions"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 10,
                  "sort": [
                    {
                      "suggested_at": {
                        "order": "desc"
                      }
                    }
                  ],
                  "_source": [
                    "data_stream_type",
                    "dataset",
                    "namespace",
                    "suggested_cluster_id",
                    "source_score",
                    "target_score",
                    "event_rate_1h",
                    "suggested_at"
                  ]
                }
              }
            }
          }
        },
        {
          "registry": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-cluster-registry"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 20,
                  "query": {
                    "match_all": {}
                  },
                  "_source": [
                    "cluster_id",
                    "cluster_uuid",
                    "cluster_name",
                    "ingest_hosts",
                    "dc",
                    "active"
                  ]
                }
              }
            }
          }
        },
        {
          "dataset_rates": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "monitoring:.monitoring-es-8-*"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 0,
                  "query": {
                    "bool": {
                      "filter": [
                        {
                          "match_phrase": {
                            "event.dataset": "elasticsearch.index"
                          }
                        },
                        {
                          "range": {
                            "@timestamp": {
                              "gte": "now-2h"
                            }
                          }
                        },
                        {
                          "bool": {
                            "should": [
                              {
                                "wildcard": {
                                  "elasticsearch.index.name": ".ds-logs-*"
                                }
                              },
                              {
                                "wildcard": {
                                  "elasticsearch.index.name": ".ds-metrics-*"
                                }
                              },
                              {
                                "wildcard": {
                                  "elasticsearch.index.name": ".ds-traces-*"
                                }
                              },
                              {
                                "wildcard": {
                                  "elasticsearch.index.name": ".ds-filebeat-*"
                                }
                              },
                              {
                                "wildcard": {
                                  "elasticsearch.index.name": "filebeat-*"
                                }
                              }
                            ],
                            "minimum_should_match": 1
                          }
                        }
                      ]
                    }
                  },
                  "aggs": {
                    "by_cluster": {
                      "terms": {
                        "field": "elasticsearch.cluster.id",
                        "size": 10
                      },
                      "aggs": {
                        "by_index": {
                          "terms": {
                            "field": "elasticsearch.index.name",
                            "size": 500
                          },
                          "aggs": {
                            "over_time": {
                              "date_histogram": {
                                "field": "@timestamp",
                                "fixed_interval": "1h"
                              },
                              "aggs": {
                                "max_total": {
                                  "max": {
                                    "field": "elasticsearch.index.total.indexing.index_total"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "existing_state": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-pipeline-state"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 500
                }
              }
            }
          }
        },
        {
          "stream_exclusions": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-stream-exclusions"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 500,
                  "_source": [
                    "topic_pattern"
                  ]
                }
              }
            }
          }
        },
        {
          "routing_locks": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-routing-config"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 500,
                  "query": {
                    "bool": {
                      "filter": [
                        {
                          "term": {
                            "config_type": "stream_lock"
                          }
                        },
                        {
                          "term": {
                            "locked": true
                          }
                        }
                      ]
                    }
                  },
                  "_source": [
                    "data_stream_type",
                    "dataset",
                    "namespace",
                    "cluster_id",
                    "pipeline_type",
                    "locked"
                  ]
                }
              }
            }
          }
        }
      ]
    }
  },
  "condition": {
    "always": {}
  },
  "transform": {
    "script": {
      "source": "// ====== CPM State Manager ======\n// Computes desired state: which dataset goes to which cluster/pipeline\n// Outputs: state entries written to cpm-pipeline-state\n\nString ts = ctx.execution_time.toString();\n\nList excludePatterns = new ArrayList();\nif (ctx.payload.stream_exclusions != null && ctx.payload.stream_exclusions.hits != null) {\n  for (def exHit : ctx.payload.stream_exclusions.hits.hits) {\n    if (exHit._source.topic_pattern != null) {\n      excludePatterns.add((String)exHit._source.topic_pattern);\n    }\n  }\n}\n\nList stateDeletions = new ArrayList();\nList suggestionDeletions = new ArrayList();\nSet suggestionDelIds = new HashSet();\n\n// Build registry map (active clusters only) and track inactive clusters\nMap registryMap = new HashMap();\nSet inactiveClusterIds = new HashSet();\nfor (def hit : ctx.payload.registry.hits.hits) {\n  Map src = hit._source;\n  String cid = (String)src.cluster_id;\n  boolean active = src.active == null || (boolean)src.active;\n  if (!active) {\n    inactiveClusterIds.add(cid);\n    if (src.cluster_uuid != null) {\n      String cu = (String)src.cluster_uuid;\n      if (!cu.equals(cid)) inactiveClusterIds.add(cu);\n    }\n    continue;\n  }\n  Map m = new HashMap();\n  m.put('cluster_id', cid);\n  m.put('cluster_uuid', (String)src.cluster_uuid);\n  m.put('cluster_name', src.cluster_name != null ? (String)src.cluster_name : '');\n  m.put('ingest_hosts', src.ingest_hosts != null ? (String)src.ingest_hosts : '');\n  m.put('dc', src.dc != null ? (String)src.dc : '');\n  registryMap.put(cid, m);\n}\n\nMap uuidRegistryMap = new HashMap();\nfor (def regEntry : registryMap.entrySet()) {\n  Map rm = (Map)regEntry.getValue();\n  uuidRegistryMap.put((String)rm.get('cluster_uuid'), rm);\n}\n\n\nMap lockMap = new HashMap();\nSet lockedTopics = new HashSet();\nif (ctx.payload.routing_locks != null && ctx.payload.routing_locks.hits != null) {\n  for (def lhit : ctx.payload.routing_locks.hits.hits) {\n    Map lsrc = lhit._source;\n    if (lsrc.locked == null || !(boolean)lsrc.locked) continue;\n    if (lsrc.cluster_id == null) continue;\n    String streamType = lsrc.data_stream_type != null ? (String)lsrc.data_stream_type : 'logs';\n    String dataset = lsrc.dataset != null ? (String)lsrc.dataset : '';\n    String namespace = lsrc.namespace != null ? (String)lsrc.namespace : 'default';\n    String topic = streamType + '-' + dataset + '-' + namespace;\n    lockMap.put(topic, lsrc);\n    lockedTopics.add(topic);\n  }\n}\n\n// ====== ROUTING LOCKS (manual overrides) ======\nList stateEntries = new ArrayList();\nSet managedTopics = new HashSet();\nSet seenClusters = new HashSet();\nSet lockedDedicatedClusters = new HashSet();\n\nfor (def topic : lockedTopics) {\n\nboolean topicExcluded = false;\nfor (int pi = 0; pi < excludePatterns.size(); pi++) {\n  String pattern = (String)excludePatterns.get(pi);\n  if (pattern.indexOf('*') < 0) {\n    if (topic.equals(pattern)) { topicExcluded = true; break; }\n  } else {\n    int star = pattern.indexOf('*');\n    String pre = pattern.substring(0, star);\n    String suf = pattern.substring(star + 1);\n    if (pre.isEmpty()) {\n      if (topic.endsWith(suf)) { topicExcluded = true; break; }\n    } else if (suf.isEmpty()) {\n      if (topic.startsWith(pre)) { topicExcluded = true; break; }\n    } else {\n      if (topic.startsWith(pre) && topic.endsWith(suf)) { topicExcluded = true; break; }\n    }\n  }\n}\n  if (topicExcluded) continue;\n  Map lsrc = (Map)lockMap.get(topic);\n  String streamType = lsrc.data_stream_type != null ? (String)lsrc.data_stream_type : 'logs';\n  String dataset = lsrc.dataset != null ? (String)lsrc.dataset : '';\n  String namespace = lsrc.namespace != null ? (String)lsrc.namespace : 'default';\n  String lockCluster = (String)lsrc.cluster_id;\n  String ptype = lsrc.pipeline_type != null ? (String)lsrc.pipeline_type : 'catchall';\n  Map cluster = (Map)registryMap.get(lockCluster);\n  if (cluster == null) continue;\n  String dc = (String)cluster.get('dc');\n  if (dc == null || dc.isEmpty()) dc = 'default';\n  if ('dedicated'.equals(ptype)) {\n    if (lockedDedicatedClusters.contains(lockCluster)) continue;\n    lockedDedicatedClusters.add(lockCluster);\n    seenClusters.add(lockCluster);\n  }\n  String pipelineId = 'dedicated'.equals(ptype)\n    ? dc + '_cpm-dedicated-' + lockCluster\n    : dc + '_cpm-catchall-' + lockCluster;\n  managedTopics.add(topic);\n  Map st = new HashMap();\n  st.put('data_stream_type', streamType);\n  st.put('dataset', dataset);\n  st.put('namespace', namespace);\n  st.put('pipeline_type', ptype);\n  st.put('pipeline_id', pipelineId);\n  st.put('cluster_id', lockCluster);\n  st.put('dc', dc);\n  st.put('topic', topic);\n  st.put('updated_at', ts);\n  stateEntries.add(st);\n}\n\n// ====== DEDICATED PIPELINES (from routing suggestions) ======\n\ndef sugDocs = ctx.payload.routing_suggestions.hits.hits;\nfor (def hit : sugDocs) {\n  Map src = hit._source;\n  String dataset    = (String)src.dataset;\n  String namespace  = src.namespace != null ? (String)src.namespace : 'default';\n  String streamType = src.data_stream_type != null ? (String)src.data_stream_type : 'logs';\n  String sugCluster = (String)src.suggested_cluster_id;\n\n  String topic = streamType + '-' + dataset + '-' + namespace;\n\n    boolean topicExcluded = false;\n    for (int pi = 0; pi < excludePatterns.size(); pi++) {\n      String pattern = (String)excludePatterns.get(pi);\n      if (pattern.indexOf('*') < 0) {\n        if (topic.equals(pattern)) { topicExcluded = true; break; }\n      } else {\n        int star = pattern.indexOf('*');\n        String pre = pattern.substring(0, star);\n        String suf = pattern.substring(star + 1);\n        if (pre.isEmpty()) {\n          if (topic.endsWith(suf)) { topicExcluded = true; break; }\n        } else if (suf.isEmpty()) {\n          if (topic.startsWith(pre)) { topicExcluded = true; break; }\n        } else {\n          if (topic.startsWith(pre) && topic.endsWith(suf)) { topicExcluded = true; break; }\n        }\n      }\n    }\n\n  if (lockedTopics.contains(topic)) continue;\n\n  if (topicExcluded) {\n    String sugId = streamType + '-' + dataset + '-' + namespace;\n    if (!suggestionDelIds.contains(sugId)) {\n      suggestionDelIds.add(sugId);\n      Map sd = new HashMap();\n      sd.put('suggestion_id', sugId);\n      suggestionDeletions.add(sd);\n    }\n    continue;\n  }\n\n  if (seenClusters.contains(sugCluster)) continue;\n  seenClusters.add(sugCluster);\n\n  Map cluster = (Map)registryMap.get(sugCluster);\n  if (cluster == null) continue;\n  String dc = (String)cluster.get('dc');\n  if (dc == null || dc.isEmpty()) dc = 'default';\n\n  String pipelineId = dc + '_cpm-dedicated-' + sugCluster;\n  managedTopics.add(topic);\n\n  Map st = new HashMap();\n  st.put('data_stream_type', streamType);\n  st.put('dataset', dataset);\n  st.put('namespace', namespace);\n  st.put('pipeline_type', 'dedicated');\n  st.put('pipeline_id', pipelineId);\n  st.put('cluster_id', sugCluster);\n  st.put('dc', dc);\n  st.put('topic', topic);\n  st.put('updated_at', ts);\n  stateEntries.add(st);\n}\n\n// ====== READ EXISTING STATE (source of truth for catchall assignments) ======\nMap stateCatchallTopics = new HashMap();\nSet stateAllTopics = new HashSet();\nList orphanedTopics = new ArrayList();\n\nif (ctx.payload.existing_state != null && ctx.payload.existing_state.hits != null) {\n  for (def hit : ctx.payload.existing_state.hits.hits) {\n    Map src = hit._source;\n    String ptype = (String)src.pipeline_type;\n    String topic = (String)src.topic;\n    String cid = (String)src.cluster_id;\n\n    if (src.data_stream_type == null) continue;\n    String streamType = (String)src.data_stream_type;\n    String dataset = src.dataset != null ? (String)src.dataset : '';\n    String ns = src.namespace != null ? (String)src.namespace : 'default';\n    if (!topic.startsWith('logs-') && !topic.startsWith('metrics-') && !topic.startsWith('traces-') && !topic.equals('filebeat')) {\n      topic = streamType + '-' + dataset + '-' + ns;\n    }\n\n    boolean topicExcluded = false;\n    for (int pi = 0; pi < excludePatterns.size(); pi++) {\n      String pattern = (String)excludePatterns.get(pi);\n      if (pattern.indexOf('*') < 0) {\n        if (topic.equals(pattern)) { topicExcluded = true; break; }\n      } else {\n        int star = pattern.indexOf('*');\n        String pre = pattern.substring(0, star);\n        String suf = pattern.substring(star + 1);\n        if (pre.isEmpty()) {\n          if (topic.endsWith(suf)) { topicExcluded = true; break; }\n        } else if (suf.isEmpty()) {\n          if (topic.startsWith(pre)) { topicExcluded = true; break; }\n        } else {\n          if (topic.startsWith(pre) && topic.endsWith(suf)) { topicExcluded = true; break; }\n        }\n      }\n    }\n\n    if (topicExcluded) {\n      Map del = new HashMap();\n      del.put('state_id', hit._id);\n      stateDeletions.add(del);\n      String sugId = streamType + '-' + dataset + '-' + ns;\n      if (!suggestionDelIds.contains(sugId)) {\n        suggestionDelIds.add(sugId);\n        Map sd = new HashMap();\n        sd.put('suggestion_id', sugId);\n        suggestionDeletions.add(sd);\n      }\n      continue;\n    }\n\n    if (managedTopics.contains(topic)) continue;\n    if (lockedTopics.contains(topic)) continue;\n\n    String cu = src.cluster_uuid != null ? (String)src.cluster_uuid : '';\n    boolean onInactive = inactiveClusterIds.contains(cid)\n      || (!cu.isEmpty() && inactiveClusterIds.contains(cu));\n    if (onInactive) {\n      orphanedTopics.add(topic);\n      continue;\n    }\n\n    if ('dedicated'.equals(ptype)) continue;\n\n    if (!stateCatchallTopics.containsKey(cid)) {\n      stateCatchallTopics.put(cid, new ArrayList());\n    }\n    ((List)stateCatchallTopics.get(cid)).add(topic);\n    stateAllTopics.add(topic);\n  }\n}\n\n// ====== DISCOVER NEW DATASETS FROM MONITORING (fallback) ======\nMap datasetClusterMap = new HashMap();\ndef rateBuckets = ctx.payload.dataset_rates.aggregations.by_cluster.buckets;\nfor (def cb : rateBuckets) {\n  String uuid = (String)cb.key;\n  for (def ib : cb.by_index.buckets) {\n    String iname = (String)ib.key;\n    String fbName = iname.startsWith('.ds-') ? iname.substring(4) : iname;\n    if (fbName.startsWith('filebeat-')) {\n      String topic = 'filebeat';\n      if (!lockedTopics.contains(topic) && !managedTopics.contains(topic) && !stateAllTopics.contains(topic)) {\n        Map cl = (Map)uuidRegistryMap.get(uuid);\n        if (cl != null) {\n          Map dm = new HashMap();\n          dm.put('cluster_id', (String)cl.get('cluster_id'));\n          dm.put('namespace', 'default');\n          dm.put('data_stream_type', 'filebeat');\n          datasetClusterMap.put('filebeat|filebeat', dm);\n        }\n      }\n      continue;\n    }\n    if (!iname.startsWith('.ds-')) continue;\n    String afterDs = iname.substring(4);\n    if (!afterDs.startsWith('logs-') && !afterDs.startsWith('metrics-') && !afterDs.startsWith('traces-')) continue;\n    String idx = afterDs;\n    int p = idx.lastIndexOf('-'); if (p <= 0) continue;\n    idx = idx.substring(0, p);\n    p = idx.lastIndexOf('-'); if (p <= 0) continue;\n    idx = idx.substring(0, p);\n    int fd = idx.indexOf('-'); if (fd <= 0) continue;\n    String streamType = idx.substring(0, fd);\n    if (!streamType.equals('logs') && !streamType.equals('metrics') && !streamType.equals('traces')) continue;\n    String rest = idx.substring(fd + 1);\n    int nd = rest.lastIndexOf('-'); if (nd <= 0) continue;\n    String dataset = rest.substring(0, nd);\n    String ns = rest.substring(nd + 1);\n    String topic = streamType + '-' + dataset + '-' + ns;\n\n    boolean topicExcluded = false;\n    for (int pi = 0; pi < excludePatterns.size(); pi++) {\n      String pattern = (String)excludePatterns.get(pi);\n      if (pattern.indexOf('*') < 0) {\n        if (topic.equals(pattern)) { topicExcluded = true; break; }\n      } else {\n        int star = pattern.indexOf('*');\n        String pre = pattern.substring(0, star);\n        String suf = pattern.substring(star + 1);\n        if (pre.isEmpty()) {\n          if (topic.endsWith(suf)) { topicExcluded = true; break; }\n        } else if (suf.isEmpty()) {\n          if (topic.startsWith(pre)) { topicExcluded = true; break; }\n        } else {\n          if (topic.startsWith(pre) && topic.endsWith(suf)) { topicExcluded = true; break; }\n        }\n      }\n    }\n\n    if (topicExcluded) continue;\n    if (lockedTopics.contains(topic)) continue;\n    if (managedTopics.contains(topic)) continue;\n    if (stateAllTopics.contains(topic)) continue;\n    Map cl = (Map)uuidRegistryMap.get(uuid);\n    if (cl != null) {\n      Map dm = new HashMap();\n      dm.put('cluster_id', (String)cl.get('cluster_id'));\n      dm.put('namespace', ns);\n      dm.put('data_stream_type', streamType);\n      datasetClusterMap.put(streamType + '|' + dataset, dm);\n    }\n  }\n}\n\n// ====== MERGE: state + new monitoring data ======\nMap clusterTopics = new HashMap(stateCatchallTopics);\nfor (def entry : datasetClusterMap.entrySet()) {\n  String mapKey = (String)entry.getKey();\n  Map dm = (Map)entry.getValue();\n  int sep = mapKey.indexOf('|');\n  String streamType = sep > 0 ? mapKey.substring(0, sep) : 'logs';\n  String dataset = sep > 0 ? mapKey.substring(sep + 1) : mapKey;\n  String cid = (String)dm.get('cluster_id');\n  String ns = (String)dm.get('namespace');\n  String topic = streamType + '-' + dataset + '-' + ns;\n  if ('filebeat'.equals(streamType)) topic = 'filebeat';\n  if (!clusterTopics.containsKey(cid)) {\n    clusterTopics.put(cid, new ArrayList());\n  }\n  ((List)clusterTopics.get(cid)).add(topic);\n}\n\n// Re-home catchall topics from deactivated clusters onto the first active cluster\nif (!orphanedTopics.isEmpty() && !registryMap.isEmpty()) {\n  String defaultCid = null;\n  for (def hit : ctx.payload.registry.hits.hits) {\n    Map src = hit._source;\n    if (src.active != null && !(boolean)src.active) continue;\n    defaultCid = (String)src.cluster_id;\n    break;\n  }\n  if (defaultCid != null) {\n    if (!clusterTopics.containsKey(defaultCid)) {\n      clusterTopics.put(defaultCid, new ArrayList());\n    }\n    List dt = (List)clusterTopics.get(defaultCid);\n    for (int oi = 0; oi < orphanedTopics.size(); oi++) {\n      String topic = (String)orphanedTopics.get(oi);\n      if (!dt.contains(topic)) dt.add(topic);\n    }\n  }\n}\n\n// ====== CATCHALL STATE ENTRIES ======\nfor (def ctEntry : clusterTopics.entrySet()) {\n  String cid = (String)ctEntry.getKey();\n  List topics = (List)ctEntry.getValue();\n  Map cluster = (Map)registryMap.get(cid);\n  if (cluster == null) continue;\n  String dc = (String)cluster.get('dc');\n  if (dc == null || dc.isEmpty()) dc = 'default';\n  String pipelineId = dc + '_cpm-catchall-' + cid;\n\n  for (int si = 0; si < topics.size(); si++) {\n    String topic = (String)topics.get(si);\n\n    boolean topicExcluded = false;\n    for (int pi = 0; pi < excludePatterns.size(); pi++) {\n      String pattern = (String)excludePatterns.get(pi);\n      if (pattern.indexOf('*') < 0) {\n        if (topic.equals(pattern)) { topicExcluded = true; break; }\n      } else {\n        int star = pattern.indexOf('*');\n        String pre = pattern.substring(0, star);\n        String suf = pattern.substring(star + 1);\n        if (pre.isEmpty()) {\n          if (topic.endsWith(suf)) { topicExcluded = true; break; }\n        } else if (suf.isEmpty()) {\n          if (topic.startsWith(pre)) { topicExcluded = true; break; }\n        } else {\n          if (topic.startsWith(pre) && topic.endsWith(suf)) { topicExcluded = true; break; }\n        }\n      }\n    }\n\n    if (topicExcluded) continue;\n    if (lockedTopics.contains(topic)) continue;\n\n    String streamType = 'logs';\n    String dsName = topic;\n    String ns = 'default';\n    if (topic.startsWith('logs-') || topic.startsWith('metrics-') || topic.startsWith('traces-')) {\n      int fd = topic.indexOf('-');\n      int ld = topic.lastIndexOf('-');\n      if (fd > 0 && ld > fd) {\n        streamType = topic.substring(0, fd);\n        dsName = topic.substring(fd + 1, ld);\n        ns = topic.substring(ld + 1);\n      }\n    } else {\n      int lastDash = topic.lastIndexOf('-');\n      dsName = lastDash > 0 ? topic.substring(0, lastDash) : topic;\n      ns = lastDash > 0 ? topic.substring(lastDash + 1) : 'default';\n    }\n    Map st = new HashMap();\n    st.put('data_stream_type', streamType);\n    st.put('dataset', dsName);\n    st.put('namespace', ns);\n    st.put('pipeline_type', 'catchall');\n    st.put('pipeline_id', pipelineId);\n    st.put('cluster_id', cid);\n    st.put('dc', dc);\n    st.put('topic', topic);\n    st.put('updated_at', ts);\n    stateEntries.add(st);\n  }\n}\n\n// Delete state documents tied to inactive clusters\nif (ctx.payload.existing_state != null && ctx.payload.existing_state.hits != null) {\n  for (def hit : ctx.payload.existing_state.hits.hits) {\n    Map src = hit._source;\n    String cid = (String)src.cluster_id;\n    String cu = src.cluster_uuid != null ? (String)src.cluster_uuid : '';\n    if (!inactiveClusterIds.contains(cid)\n        && (cu.isEmpty() || !inactiveClusterIds.contains(cu))) continue;\n    Map del = new HashMap();\n    del.put('state_id', hit._id);\n    stateDeletions.add(del);\n  }\n}\n\n// Cleanup: remove any remaining excluded state and routing suggestions\nSet delStateIds = new HashSet();\nfor (int di = 0; di < stateDeletions.size(); di++) {\n  delStateIds.add((String)((Map)stateDeletions.get(di)).get('state_id'));\n}\nif (ctx.payload.existing_state != null && ctx.payload.existing_state.hits != null) {\n  for (def hit : ctx.payload.existing_state.hits.hits) {\n    if (delStateIds.contains(hit._id)) continue;\n    Map src = hit._source;\n    if (src.data_stream_type == null) continue;\n    String streamType = (String)sr