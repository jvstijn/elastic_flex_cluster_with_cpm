{% raw %}
{
  "trigger": {
    "schedule": {
      "cron": "0 0 0 * * ?"
    }
  },
  "input": {
    "chain": {
      "inputs": [
        {
          "existing_registry": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "cpm-cluster-registry"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 100
                }
              }
            }
          }
        },
        {
          "monitoring_clusters": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "monitoring:.monitoring-es-8-*"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 0,
                  "query": {
                    "bool": {
                      "filter": [
                        {
                          "match_phrase": {
                            "event.dataset": "elasticsearch.cluster.stats"
                          }
                        },
                        {
                          "range": {
                            "@timestamp": {
                              "gte": "now-1d"
                            }
                          }
                        }
                      ]
                    }
                  },
                  "aggs": {
                    "by_cluster": {
                      "terms": {
                        "field": "elasticsearch.cluster.id",
                        "size": 20
                      },
                      "aggs": {
                        "cluster_name": {
                          "terms": {
                            "field": "elasticsearch.cluster.name",
                            "size": 1
                          }
                        },
                        "latest_doc": {
                          "top_hits": {
                            "size": 1,
                            "sort": [
                              {
                                "@timestamp": "desc"
                              }
                            ],
                            "_source": {
                              "includes": [
                                "elasticsearch.cluster.stats.state.nodes"
                              ]
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "node_capacity": {
            "search": {
              "request": {
                "search_type": "query_then_fetch",
                "indices": [
                  "monitoring:.monitoring-es-8-*"
                ],
                "rest_total_hits_as_int": true,
                "body": {
                  "size": 0,
                  "query": {
                    "bool": {
                      "filter": [
                        {
                          "match_phrase": {
                            "event.dataset": "elasticsearch.node.stats"
                          }
                        },
                        {
                          "range": {
                            "@timestamp": {
                              "gte": "now-1d"
                            }
                          }
                        },
                        {
                          "terms": {
                            "elasticsearch.node.roles": [
                              "data",
                              "data_content",
                              "data_hot",
                              "data_cold",
                              "data_warm"
                            ]
                          }
                        }
                      ]
                    }
                  },
                  "aggs": {
                    "by_cluster": {
                      "terms": {
                        "field": "elasticsearch.cluster.id",
                        "size": 20
                      },
                      "aggs": {
                        "by_node": {
                          "terms": {
                            "field": "elasticsearch.node.id",
                            "size": 200
                          },
                          "aggs": {
                            "disk_total": {
                              "max": {
                                "field": "elasticsearch.node.stats.fs.summary.total.bytes"
                              }
                            },
                            "heap_max": {
                              "max": {
                                "field": "elasticsearch.node.stats.jvm.mem.heap.max.bytes"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  },
  "condition": {
    "script": {
      "source": "ctx.payload.monitoring_clusters.aggregations.by_cluster.buckets.size() > 0",
      "lang": "painless"
    }
  },
  "transform": {
    "script": {
      "source": "Map existing = new HashMap();\nfor (def hit : ctx.payload.existing_registry.hits.hits) {\n  def s = hit._source;\n  Map m = new HashMap();\n  if (s.containsKey('cluster_id'))            m['cluster_id']            = s['cluster_id'];\n  if (s.containsKey('cluster_name'))           m['cluster_name']           = s['cluster_name'];\n  if (s.containsKey('active'))                 m['active']                 = s['active'];\n  if (s.containsKey('dc'))                     m['dc']                     = s['dc'];\n  if (s.containsKey('ingest_hosts'))           m['ingest_hosts']           = s['ingest_hosts'];\n  if (s.containsKey('ingest_capacity_per_day')) m['ingest_capacity_per_day'] = s['ingest_capacity_per_day'];\n  existing[(String)s['cluster_uuid']] = m;\n}\n\n// Extract dc from cluster stats node attributes\nMap dcMap = new HashMap();\nfor (def cb : ctx.payload.monitoring_clusters.aggregations.by_cluster.buckets) {\n  String uuid = (String)cb.key;\n  if (cb.latest_doc.hits.hits.size() > 0) {\n    def src = cb.latest_doc.hits.hits[0]._source;\n    def esNode = src.elasticsearch;\n    if (esNode != null) {\n      def stats = esNode.cluster.stats;\n      if (stats != null && stats.state != null && stats.state.nodes != null) {\n        def nodes = stats.state.nodes;\n        for (def nodeEntry : nodes.entrySet()) {\n          def nodeVal = nodeEntry.getValue();\n          if (nodeVal != null && nodeVal.attributes != null) {\n            if (nodeVal.attributes.dc != null) {\n              dcMap.put(uuid, (String)nodeVal.attributes.dc);\n              break;\n            }\n            if (nodeVal.attributes.region != null) {\n              dcMap.put(uuid, (String)nodeVal.attributes.region);\n              break;\n            }\n          }\n        }\n      }\n    }\n  }\n}\n\nMap capacityMap = new HashMap();\nfor (def cb : ctx.payload.node_capacity.aggregations.by_cluster.buckets) {\n  String cid = (String)cb.key;\n  long totalDisk = 0L;\n  long totalHeap = 0L;\n  int nodeCount = 0;\n  for (def nb : cb.by_node.buckets) {\n    if (nb.disk_total.value != null) totalDisk += ((Number)nb.disk_total.value).longValue();\n    if (nb.heap_max.value != null)   totalHeap += ((Number)nb.heap_max.value).longValue();\n    nodeCount++;\n  }\n  Map cap = new HashMap();\n  cap['disk_total_bytes'] = totalDisk;\n  cap['heap_max_bytes']   = totalHeap;\n  cap['node_count']       = nodeCount;\n  capacityMap[cid] = cap;\n}\n\nList clusters = new ArrayList();\nfor (def b : ctx.payload.monitoring_clusters.aggregations.by_cluster.buckets) {\n  String uuid = (String)b.key;\n  String name = b.cluster_name.buckets.size() > 0 ? (String)b.cluster_name.buckets[0].key : uuid;\n\n  Map ex  = existing.containsKey(uuid)  ? (Map)existing[uuid]  : new HashMap();\n  Map cap = capacityMap.containsKey(uuid) ? (Map)capacityMap[uuid] : new HashMap();\n\n  long diskTotal = cap.containsKey('disk_total_bytes') ? ((Number)cap['disk_total_bytes']).longValue() * 85L / 100L : 0L;\n  long heapMax   = cap.containsKey('heap_max_bytes')   ? ((Number)cap['heap_max_bytes']).longValue()   : 0L;\n  int  nodeCount = cap.containsKey('node_count')       ? ((Number)cap['node_count']).intValue()        : 0;\n\n  int shardMax = heapMax > 0L\n    ? (int)Math.round((double)heapMax / 1073741824.0 * 20.0)\n    : 1000;\n\n  long queueThresh = 200L;\n\n  Map c = new HashMap();\n  c['cluster_uuid']            = uuid;\n  c['cluster_id']              = ex.containsKey('cluster_id')            ? (String)ex['cluster_id']            : uuid;\n  c['cluster_name']            = ex.containsKey('cluster_name')           ? (String)ex['cluster_name']           : name;\n  c['dc']                      = dcMap.containsKey(uuid)                 ? (String)dcMap[uuid]                 : (ex.containsKey('dc') ? (String)ex['dc'] : '');\n  c['disk_total_bytes']        = diskTotal;\n  c['heap_max_bytes']          = heapMax;\n  c['node_count']             = nodeCount;\n  c['shard_max_threshold']    = shardMax;\n  c['write_queue_threshold']  = queueThresh;\n  c['active']                  = ex.containsKey('active') ? (boolean)ex['active'] : true;\n  if (ex.containsKey('ingest_hosts'))            c['ingest_hosts']            = (String)ex['ingest_hosts'];\n  if (ex.containsKey('ingest_capacity_per_day')) c['ingest_capacity_per_day'] = ((Number)ex['ingest_capacity_per_day']).longValue();\n  clusters.add(c);\n}\n\nMap out = new HashMap();\nout['clusters'] = clusters;\nreturn out;",
      "lang": "painless"
    }
  },
  "actions": {
    "bulk_upsert": {
      "webhook": {
        "scheme": "https",
        "host": "{% endraw %}{{ webhook_host }}{% raw %}",
        "port": 9200,
        "method": "post",
        "path": "/_bulk",
        "params": {},
        "headers": {
          "Authorization": "ApiKey {% endraw %}{{ watcher_api_key.encoded }}{% raw %}",
          "Content-Type": "application/x-ndjson"
        },
        "body": "{{#ctx.payload.clusters}}{\"index\":{\"_index\":\"cpm-cluster-registry\",\"_id\":\"{{{cluster_uuid}}}\"}}\n{\"cluster_uuid\":\"{{{cluster_uuid}}}\",\"cluster_id\":\"{{{cluster_id}}}\",\"cluster_name\":\"{{{cluster_name}}}\",\"dc\":\"{{{dc}}}\",\"disk_total_bytes\":{{disk_total_bytes}},\"heap_max_bytes\":{{heap_max_bytes}},\"node_count\":{{node_count}},\"shard_max_threshold\":{{shard_max_threshold}},\"write_queue_threshold\":{{write_queue_threshold}},\"active\":{{active}}{{#ingest_hosts}},\"ingest_hosts\":\"{{{.}}}\"{{/ingest_hosts}}{{#ingest_capacity_per_day}},\"ingest_capacity_per_day\":{{.}}{{/ingest_capacity_per_day}}}\n{{/ctx.payload.clusters}}"
      }
    }
  }
}
{% endraw %}
